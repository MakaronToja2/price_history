# Copy to .env and fill in values. Do NOT commit .env.

# Django
DJANGO_SECRET_KEY=replace-with-long-random-string-for-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# PostgreSQL (transactional)
POSTGRES_DB=price_history
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# TimescaleDB (time-series)
TIMESCALE_DB=price_timeseries
TIMESCALE_USER=postgres
TIMESCALE_PASSWORD=postgres
TIMESCALE_HOST=timescaledb
TIMESCALE_PORT=5432

# Redis / Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# JWT
JWT_ACCESS_LIFETIME_MINUTES=15
JWT_REFRESH_LIFETIME_DAYS=7

# Allegro API
# Production endpoint requires app verification for /offers/listing — Allegro
# only grants it to vetted business applications (https://developer.allegro.pl/news/get-offers-listing-tylko-dla-zweryfikowanych-aplikacji-GRax4oVgrs1).
# For the lab project / development, use the SANDBOX. Register at
# https://apps.developer.allegro.pl.allegrosandbox.pl/ and use these URLs:
#   ALLEGRO_API_BASE_URL=https://api.allegro.pl.allegrosandbox.pl
#   ALLEGRO_AUTH_URL=https://allegro.pl.allegrosandbox.pl/auth/oauth/token
ALLEGRO_CLIENT_ID=
ALLEGRO_CLIENT_SECRET=
ALLEGRO_API_BASE_URL=https://api.allegro.pl.allegrosandbox.pl
ALLEGRO_AUTH_URL=https://allegro.pl.allegrosandbox.pl/auth/oauth/token

# Amazon scraper
AMAZON_DOMAIN_DEFAULT=amazon.pl
AMAZON_SCRAPER_CONCURRENCY=3
AMAZON_RATE_LIMIT_DELAY_SECONDS=30
AMAZON_TIMEOUT_SECONDS=30

# Gmail SMTP
GMAIL_USER=
GMAIL_APP_PASSWORD=
