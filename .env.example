# Copy to .env and fill in values. Do NOT commit .env.

# Django
DJANGO_SECRET_KEY=replace-with-long-random-string-for-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# PostgreSQL (transactional)
POSTGRES_DB=price_history
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# TimescaleDB (time-series)
TIMESCALE_DB=price_timeseries
TIMESCALE_USER=postgres
TIMESCALE_PASSWORD=postgres
TIMESCALE_HOST=timescaledb
TIMESCALE_PORT=5432

# Redis / Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# JWT
JWT_ACCESS_LIFETIME_MINUTES=15
JWT_REFRESH_LIFETIME_DAYS=7

# Allegro API (Phase 4)
ALLEGRO_CLIENT_ID=
ALLEGRO_CLIENT_SECRET=
ALLEGRO_API_BASE_URL=https://api.allegro.pl
ALLEGRO_AUTH_URL=https://allegro.pl/auth/oauth/token

# Amazon scraper (Phase 4)
AMAZON_DOMAIN_DEFAULT=amazon.pl
AMAZON_SCRAPER_CONCURRENCY=3
AMAZON_RATE_LIMIT_DELAY_SECONDS=30
AMAZON_TIMEOUT_SECONDS=30

# Gmail SMTP (Phase 7)
GMAIL_USER=
GMAIL_APP_PASSWORD=
